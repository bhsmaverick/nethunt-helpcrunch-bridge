# NetHunt - HelpCrunch Bridge - Production Environment Template
# Copy this file to .env and fill in the real values.
# The application stores settings in SQLite, but this file serves as a single source
# for deployment-time configuration. You can inject these values into the DB via
# the admin UI or by running the init_settings script.

# --- HelpCrunch ---
HELP_CRUNCH_API_KEY=
HELP_CRUNCH_SUBDOMAIN=
HELP_CRUNCH_WEBHOOK_SECRET=

# --- NetHunt ---
NETHUNT_API_EMAIL=
NETHUNT_API_KEY=
NETHUNT_BASE_URL=https://nethunt.com
NETHUNT_WORKSPACE_ID=
NETHUNT_CONTACTS_FOLDER=
NETHUNT_DEALS_FOLDER=

# --- Field mapping ---
SYNC_PRIORITY=email,phone,telegram
TELEGRAM_FIELD_HC=telegram
TELEGRAM_FIELD_NH=Telegram
INSTAGRAM_FIELD_NH=Instagram
PHONE_FIELD_NH=Phone
EMAIL_FIELD_NH=Email
HC_ID_FIELD_NH=HelpCrunch ID
UPDATE_NH_CHAT_LINK=false
NH_CHAT_LINK_FIELD=Лінк на HelpCrunch

# --- UTM / Source tracking ---
UTM_SOURCE_FIELD_NH=utm_source
UTM_MEDIUM_FIELD_NH=utm_medium
UTM_CAMPAIGN_FIELD_NH=utm_campaign
UTM_TERM_FIELD_NH=utm_term
UTM_CONTENT_FIELD_NH=utm_content
GCLID_FIELD_NH=gclid
REFERER_FIELD_NH=Referer
SOURCE_FIELD_NH=Source
COUNTRY_FIELD_NH=Country
CITY_FIELD_NH=City
